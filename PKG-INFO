from __future__ import annotations

import json
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

from aibrief.utils.io import atomic_write_text
from aibrief.utils.validation import validate_output_path


def build_health_payload(report: dict[str, Any], *, status: str = "ok") -> dict[str, Any]:
    now = datetime.now(timezone.utc)
    return {
        "status": status,
        "generated_at": now.isoformat(),
        "run_id": report.get("run_id", ""),
        "topic": report.get("topic", ""),
        "pipeline_started_at": report.get("started_at", ""),
        "metrics": report.get("metrics", {}),
        "errors": report.get("errors", []),
    }


def write_health_files(report: dict[str, Any], web_root: str | Path = "web") -> None:
    root = validate_output_path(str(web_root))
    root.mkdir(parents=True, exist_ok=True)
    health = build_health_payload(report)
    atomic_write_text(root / "health.json", json.dumps(health, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
    health_dir = root / "health"
    health_dir.mkdir(parents=True, exist_ok=True)
    # Static hosting fallback for /health. Dynamic Docker runtime overrides this with JSON status.
    atomic_write_text(
        health_dir / "index.html",
        json.dumps(health, ensure_ascii=False, indent=2, sort_keys=True) + "\n",
    )
