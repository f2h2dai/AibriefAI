from __future__ import annotations

import json
import os
import tempfile
from pathlib import Path
from typing import Any

from aibrief.utils.validation import validate_output_path


def atomic_write_text(path: str | Path, text: str) -> None:
    """Write text atomically and fsync the file and containing directory."""
    target = validate_output_path(path)
    target.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=f".{target.name}.", suffix=".tmp", dir=str(target.parent), text=True)
    tmp = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(text)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, target)
        try:
            dir_fd = os.open(target.parent, os.O_DIRECTORY)
            try:
                os.fsync(dir_fd)
            finally:
                os.close(dir_fd)
        except OSError:
            pass
    except Exception:
        try:
            tmp.unlink(missing_ok=True)
        finally:
            raise


def read_json_file(path: str | Path) -> dict[str, Any]:
    p = Path(path)
    data = json.loads(p.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise ValueError("JSON root must be an object")
    return data


def write_report(data: dict[str, Any], path: str | Path) -> None:
    atomic_write_text(path, json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")


def write_web_feed(data: dict[str, Any], path: str | Path) -> None:
    signals = data.get("signals", [])
    if not isinstance(signals, list):
        signals = []
    feed = {
        "generatedAt": data.get("started_at"),
        "runId": data.get("run_id"),
        "topic": data.get("topic"),
        "metrics": data.get("metrics", {}) if isinstance(data.get("metrics", {}), dict) else {},
        "errors": data.get("errors", []) if isinstance(data.get("errors", []), list) else [],
        "signals": signals,
    }
    atomic_write_text(path, json.dumps(feed, ensure_ascii=False, indent=2, sort_keys=True) + "\n")


def append_jsonl(path: str | Path, record: dict[str, Any]) -> None:
    """Append one JSON object to a JSONL file without logging secrets."""
    target = validate_output_path(path)
    target.parent.mkdir(parents=True, exist_ok=True)
    line = json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n"
    with target.open("a", encoding="utf-8") as handle:
        handle.write(line)
        handle.flush()
        os.fsync(handle.fileno())
