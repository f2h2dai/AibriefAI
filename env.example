<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'unsafe-inline' 'self'; style-src 'unsafe-inline' 'self'; img-src 'self' data:; connect-src 'self'; base-uri 'none'; form-action 'none'">
  <title>Aibrief إحاطة AI</title>
  <style>
    :root{--bg:#050505;--panel:#0c0c0e;--text:#f4f4f4;--muted:#9a9aa1;--muted2:#66666d;--line:#242428;--ok:#a7f3d0;--hold:#fde68a;--warn:#e8e36a}
    *{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--bg);color:var(--text);font:14px/1.5 Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}a{color:inherit;text-decoration:none}
    .shell{width:min(1120px,100%);margin:auto;background:radial-gradient(circle at 50% 0,#17171a 0,#080809 32%,#050505 100%);min-height:100vh;border-left:1px solid #101012;border-right:1px solid #101012}.nav{position:sticky;top:0;z-index:10;display:flex;align-items:center;justify-content:space-between;padding:18px 56px;background:rgba(5,5,5,.72);backdrop-filter:blur(18px);border-bottom:1px solid rgba(255,255,255,.06)}.brand{display:flex;gap:10px;align-items:center;font-weight:650}.dot{width:9px;height:9px;border-radius:99px;background:var(--warn);box-shadow:0 0 18px rgba(232,227,106,.35)}.navlinks{display:flex;gap:22px;color:var(--muted);font-size:12px}.hero{padding:78px 56px 52px;text-align:center}.eyebrow{font-size:12px;color:var(--muted);letter-spacing:.14em;text-transform:uppercase}.hero h1{font-size:58px;letter-spacing:-.07em;line-height:.92;margin:18px auto 16px;max-width:750px;font-weight:720}.hero p{color:var(--muted);max-width:620px;margin:0 auto 28px;font-size:16px}.cta{display:inline-flex;gap:8px;align-items:center;border:1px solid var(--line);background:#f2f2f2;color:#080808;border-radius:999px;padding:10px 14px;font-weight:650;font-size:13px}.mock{width:min(720px,88%);margin:42px auto 0;border:1px solid #252528;background:linear-gradient(180deg,#151519,#0b0b0c);border-radius:14px;box-shadow:0 30px 120px rgba(255,255,255,.06);overflow:hidden;text-align:left}.mockbar{height:38px;border-bottom:1px solid #242428;display:flex;gap:7px;align-items:center;padding:0 13px}.mockbar i{width:8px;height:8px;background:#38383d;border-radius:50%}.mockgrid{display:grid;grid-template-columns:190px 1fr 180px;min-height:260px}.side,.inspect{border-right:1px solid #1d1d20;padding:16px;color:#777;font-size:12px}.inspect{border-right:0;border-left:1px solid #1d1d20}.feed{padding:16px}.item{padding:12px;border:1px solid #202024;border-radius:10px;background:#0e0e10;margin-bottom:10px}.item b{display:block;color:#f4f4f4;margin-bottom:5px}.meta{color:#85858b;font-size:11px}.section{display:grid;grid-template-columns:320px 1fr;gap:78px;padding:86px 56px;border-top:1px solid rgba(255,255,255,.06)}.section h2{font-size:31px;line-height:1.02;letter-spacing:-.05em;margin:0 0 18px}.section p{color:var(--muted);margin:0 0 18px}.cards{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}.card{border:1px solid var(--line);background:rgba(255,255,255,.025);border-radius:14px;padding:18px;min-height:130px}.card .k{font-size:11px;color:var(--muted2);text-transform:uppercase;letter-spacing:.12em}.card h3{font-size:17px;margin:11px 0 8px;line-height:1.15}.card p{font-size:13px;margin:0;color:#8b8b91}.score{font-size:32px;letter-spacing:-.05em}.pill{display:inline-flex;border:1px solid #2a2a2e;border-radius:999px;padding:5px 8px;color:#a8a8ad;font-size:11px;margin:3px 5px 0 0}.toolbar{display:flex;gap:8px;margin-bottom:16px}.toolbar input,.toolbar select{background:#080809;color:#f0f0f0;border:1px solid #252529;border-radius:10px;padding:10px;width:100%}.signal{border-top:1px solid #1b1b1e;padding:18px 0}.signal:first-child{border-top:0}.signal h3{margin:0 0 7px;font-size:20px;letter-spacing:-.03em}.signal p{font-size:13px;margin:7px 0}.status{font-size:11px;border-radius:999px;padding:4px 7px;border:1px solid #2b2b30;color:#bbb}.approved{color:var(--ok)}.pending,.held{color:var(--hold)}.arabic{direction:rtl;text-align:right;font-family:Tahoma,Arial,sans-serif;color:#d8d8d8}.rail{position:fixed;right:26px;top:26px;display:flex;gap:8px}.rail span{width:8px;height:8px;border-radius:50%;background:#fff;opacity:.9}.footer{padding:70px 56px;border-top:1px solid rgba(255,255,255,.06);color:#777;display:flex;justify-content:space-between}.code{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;color:#aaa;font-size:12px}.empty{color:#777;border:1px dashed #29292e;border-radius:14px;padding:24px;text-align:center}.error{border:1px solid #5c2a2a;background:#1b0d0d;color:#f0caca;border-radius:12px;padding:12px;margin-top:16px;text-align:left}@media(max-width:760px){.nav,.hero,.section,.footer{padding-left:22px;padding-right:22px}.hero h1{font-size:42px}.section{grid-template-columns:1fr;gap:28px}.cards{grid-template-columns:1fr}.mockgrid{grid-template-columns:1fr}.side,.inspect{display:none}.rail{display:none}.toolbar{flex-direction:column}}
  </style>
</head>
<body>
<div class="rail" aria-hidden="true"><span></span><span></span><span></span></div>
<main class="shell">
  <nav class="nav">
    <div class="brand"><span class="dot" aria-hidden="true"></span> Aibrief إحاطة AI</div>
    <div class="navlinks"><a href="#signals">Signals</a><a href="#workflow">Workflow</a><a href="#topics">Topics</a><a href="#briefs">Briefs</a></div>
  </nav>

  <section class="hero">
    <div class="eyebrow">AI intelligence curation</div>
    <h1>The intelligence system for teams and agents</h1>
    <p>Aibrief monitors AI sources, scores signals, runs structured review, and generates English/Arabic briefs for executive decisions.</p>
    <a class="cta" href="#signals">View live feed →</a>
    <div id="loadError" class="error" hidden></div>
    <div class="mock">
      <div class="mockbar"><i></i><i></i><i></i></div>
      <div class="mockgrid">
        <div class="side">Sources<br><br>arXiv<br>GitHub<br>RSS<br>HackerNews<br>X Influencers</div>
        <div class="feed" id="mockFeed"></div>
        <div class="inspect">Review<br><br>Score<br>Confidence<br>Risk notes<br>Arabic brief</div>
      </div>
    </div>
  </section>

  <section class="section" id="workflow">
    <div><h2>Make intelligence operations self-driving</h2><p>A multi-agent workflow reviews each signal before it reaches the dashboard.</p></div>
    <div class="cards">
      <div class="card"><div class="k">01</div><h3>Source analysts</h3><p>Normalize research, code, industry, discussion, and social signals.</p></div>
      <div class="card"><div class="k">02</div><h3>Scoring and verification</h3><p>Apply deterministic scoring and confidence checks before enrichment.</p></div>
      <div class="card"><div class="k">03</div><h3>Debate and risk</h3><p>Opportunity and skeptic agents produce a review trail.</p></div>
      <div class="card"><div class="k">04</div><h3>Manager approval</h3><p>Only approved signals become bilingual briefs.</p></div>
    </div>
  </section>

  <section class="section" id="topics">
    <div><h2>Define the signal direction</h2><p>Track the fields that matter to AI leadership and engineering teams.</p></div>
    <div class="cards" id="topicCards"></div>
  </section>

  <section class="section" id="signals">
    <div><h2>Understand progress at scale</h2><p>Search the feed, filter by source, and inspect the review status.</p><div class="code" id="metrics"></div></div>
    <div>
      <div class="toolbar"><input id="q" placeholder="Search signals" autocomplete="off"><select id="source"><option value="all">All sources</option></select></div>
      <div id="signalsList"></div>
    </div>
  </section>

  <section class="section" id="briefs">
    <div><h2>Review bilingual agent output</h2><p>Each approved story gets English and Arabic summaries with risk notes.</p></div>
    <div id="briefList"></div>
  </section>

  <footer class="footer"><span>Aibrief — إحاطة AI</span><span class="code">rule-based cost path · bilingual output · checkpointed workflow</span></footer>
</main>
<script>
'use strict';
let FEED={signals:[],metrics:{},errors:[]};
const fallback={signals:[{source:'seed',title:'Run the pipeline to generate signals',content:'Use python scripts/run_pipeline.py --topic ai-agents --limit 8 --emit-html',score:0,status:'held',topic:'AI Intelligence',threadEn:'No generated brief yet.',threadAr:'شغّل خط الأنابيب لتوليد الموجز.',riskNotes:'waiting for pipeline',confidenceScore:0}],metrics:{approved:0,held:1,total_signals:1,avg_score:0},errors:[]};
function byId(id){return document.getElementById(id)}
function uniq(a){return [...new Set(a.filter(Boolean))]}
function esc(s){return String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]))}
function validFeed(data){return data && Array.isArray(data.signals) && typeof data.metrics==='object'}
async function load(){
  try{
    const r=await fetch('data/signals.json',{cache:'no-store'});
    if(!r.ok) throw new Error('feed returned '+r.status);
    const data=await r.json();
    FEED=validFeed(data)?data:fallback;
  }catch(e){
    FEED=fallback;
    const box=byId('loadError');
    box.hidden=false;
    box.textContent='Feed file could not be loaded. The local fallback is shown. Run the pipeline to regenerate web/data/signals.json.';
  }
  render();
}
function render(){
 const signals=Array.isArray(FEED.signals)?FEED.signals:[]; const sources=uniq(signals.map(s=>s.source));
 const current=byId('source').value || 'all';
 byId('source').innerHTML='<option value="all">All sources</option>'+sources.map(s=>`<option value="${esc(s)}">${esc(s)}</option>`).join('');
 byId('source').value=sources.includes(current)?current:'all';
 const m=FEED.metrics||{};
 byId('metrics').textContent=`signals=${m.total_signals??signals.length} approved=${m.approved??0} held=${m.held??0} avg_score=${m.avg_score??0} errors=${m.error_count??(FEED.errors||[]).length}`;
 byId('mockFeed').innerHTML=signals.slice(0,3).map(s=>`<div class="item"><b>${esc(s.title)}</b><span class="meta">${esc(s.source)} · ${Number(s.score||0)}/100 · ${esc(s.status)}</span></div>`).join('') || '<div class="empty">No signals loaded.</div>';
 const topics=uniq(signals.map(s=>s.topic||'AI Intelligence'));
 byId('topicCards').innerHTML=topics.map(t=>{const c=signals.filter(s=>(s.topic||'AI Intelligence')===t).length;return `<div class="card"><div class="k">Topic</div><h3>${esc(t)}</h3><p>${c} related signals in this run.</p></div>`}).join('') || '<div class="empty">No topics found.</div>';
 drawSignals();
}
function drawSignals(){
 const q=byId('q').value.toLowerCase(); const src=byId('source').value; let signals=Array.isArray(FEED.signals)?FEED.signals:[];
 signals=signals.filter(s=>(src==='all'||s.source===src)&&(`${s.title||''} ${s.content||''} ${s.topic||''}`.toLowerCase().includes(q)));
 byId('signalsList').innerHTML=signals.length?signals.map(s=>`<article class="signal"><span class="status ${s.status==='enriched'?'approved':'held'}">${esc(s.status)}</span><h3>${esc(s.title)}</h3><div class="meta">${esc(s.source)} · ${esc(s.topic)} · score ${Number(s.score||0)}/100 · confidence ${Number(s.confidenceScore||0)}</div><p>${esc(s.content)}</p><span class="pill">${esc(s.riskNotes)}</span></article>`).join(''):'<div class="empty">No matching signals.</div>';
 const briefSignals=signals.filter(s=>s.status==='enriched').slice(0,6);
 byId('briefList').innerHTML=(briefSignals.length?briefSignals:signals.slice(0,6)).map(s=>`<article class="signal"><h3>${esc(s.title)}</h3><p>${esc(s.threadEn)}</p><p class="arabic">${esc(s.threadAr)}</p></article>`).join('') || '<div class="empty">No briefs generated.</div>';
}
byId('q').addEventListener('input',drawSignals);byId('source').addEventListener('change',drawSignals);load();
</script>
</body>
</html>
