from __future__ import annotations

import html
from pathlib import Path
from typing import Any

from aibrief.utils.io import atomic_write_text


def _safe_int(value: Any, default: int = 0) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return default


def build_html_brief(report: dict[str, Any]) -> str:
    topic = html.escape(str(report.get("topic", "Aibrief إحاطة AI Brief")))
    metrics = report.get("metrics", {}) if isinstance(report.get("metrics", {}), dict) else {}
    signals = report.get("signals", [])[:8] if isinstance(report.get("signals", []), list) else []
    best_takes = metrics.get("best_takes", []) if isinstance(metrics.get("best_takes", []), list) else []

    def signal_card(sig: dict[str, Any]) -> str:
        status = html.escape(str(sig.get("status", "held")))
        risk = html.escape(str(sig.get("riskNotes", "source review required")))
        return f"""
        <article class='card'>
          <div class='meta'>{html.escape(str(sig.get('source','')))} · score {_safe_int(sig.get('score'))} · engagement {_safe_int(sig.get('engagement'))} · {status}</div>
          <h2>{html.escape(str(sig.get('title','')))}</h2>
          <p>{html.escape(str(sig.get('content','')))}</p>
          <p class='risk'>Risk: {risk}</p>
          <p class='ar' dir='rtl'>{html.escape(str(sig.get('threadAr','')))}</p>
        </article>
        """

    takes_html = "".join(
        f"<li><b>{html.escape(str(t.get('source','')))}</b>: {html.escape(str(t.get('take','')))}</li>" for t in best_takes
    ) or "<li>No best takes selected.</li>"

    cards = "".join(signal_card(s) for s in signals if isinstance(s, dict))
    return f"""<!doctype html>
<html lang='en'>
<head>
<meta charset='utf-8'><meta name='viewport' content='width=device-width,initial-scale=1'>
<meta http-equiv='Content-Security-Policy' content="default-src 'none'; style-src 'unsafe-inline'; img-src 'self' data:; base-uri 'none'; form-action 'none'">
<title>Aibrief إحاطة AI Brief - {topic}</title>
<style>
body{{margin:0;background:#050505;color:#f2f2f2;font:14px/1.55 Inter,system-ui,sans-serif}}
main{{max-width:920px;margin:auto;padding:56px 22px}}.eyebrow{{color:#999;text-transform:uppercase;letter-spacing:.14em;font-size:12px}}
h1{{font-size:46px;letter-spacing:-.05em;line-height:1;margin:12px 0 20px}}.stats{{display:flex;gap:10px;flex-wrap:wrap;margin:20px 0 38px}}
.stat{{border:1px solid #242428;border-radius:999px;padding:8px 12px;color:#bbb}}.card{{border-top:1px solid #222;padding:28px 0}}
.card h2{{font-size:22px;line-height:1.1;margin:8px 0 10px}}.card p{{color:#b8b8b8}}.meta{{color:#85858b;font-size:12px}}.risk{{color:#d5d092}}.ar{{text-align:right;font-family:Tahoma,Arial,sans-serif;color:#dcdcdc}}
li{{margin:10px 0;color:#c9c9c9}}footer{{border-top:1px solid #222;margin-top:40px;padding-top:20px;color:#777}}
</style>
</head>
<body><main>
<div class='eyebrow'>Aibrief إحاطة AI last 30 days brief</div><h1>{topic}</h1>
<div class='stats'><span class='stat'>signals {_safe_int(metrics.get('total_signals'), len(signals))}</span><span class='stat'>approved {_safe_int(metrics.get('approved'))}</span><span class='stat'>held {_safe_int(metrics.get('held'))}</span><span class='stat'>clusters {_safe_int(metrics.get('clusters'))}</span><span class='stat'>engagement {_safe_int(metrics.get('total_engagement'))}</span></div>
<h2>Best takes</h2><ol>{takes_html}</ol>
{cards}
<footer>Generated by Aibrief. Sources require editorial verification before publication.</footer>
</main></body></html>"""


def write_html_brief(report: dict[str, Any], output_path: str | Path) -> Path:
    output = Path(output_path)
    atomic_write_text(output, build_html_brief(report))
    return output
