#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from datetime import datetime, timezone
from pathlib import Path


def main() -> int:
    parser = argparse.ArgumentParser(description="Summarize free-tier LLM usage logs")
    parser.add_argument("--usage-dir", default="data/usage")
    args = parser.parse_args()
    today = datetime.now(timezone.utc).date().isoformat()
    path = Path(args.usage_dir) / f"llm_usage_{today}.jsonl"
    if not path.exists():
        print("no LLM usage logged today")
        return 0
    totals: dict[str, dict[str, int | float]] = {}
    for line in path.read_text(encoding="utf-8").splitlines():
        if not line.strip():
            continue
        record = json.loads(line)
        provider = str(record.get("provider", "unknown"))
        item = totals.setdefault(provider, {"input_tokens": 0, "output_tokens": 0, "estimated_cost_usd": 0.0})
        item["input_tokens"] = int(item["input_tokens"]) + int(record.get("input_tokens") or 0)
        item["output_tokens"] = int(item["output_tokens"]) + int(record.get("output_tokens") or 0)
        item["estimated_cost_usd"] = float(item["estimated_cost_usd"]) + float(record.get("estimated_cost_usd") or 0.0)
    print(json.dumps(totals, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
